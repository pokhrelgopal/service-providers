# Production environment for docker-compose.prod.yml. Copy to .env.prod and fill.
# NEVER commit the real .env.prod.

# --- Postgres ---
POSTGRES_USER=servio
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=marketplace

# --- MinIO ---
MINIO_ROOT_USER=change-me
MINIO_ROOT_PASSWORD=change-me-strong

# --- API (consumed by backend via env_file) ---
NODE_ENV=production
API_PORT=5000
WEB_ORIGIN=https://app.yourdomain.com
# Service hostnames are the compose service names on the internal network:
DATABASE_URL=postgres://servio:change-me-strong@postgres:5432/marketplace
REDIS_URL=redis://redis:6379
JWT_ACCESS_SECRET=change-me-long-random
JWT_REFRESH_SECRET=change-me-long-random

# Google OAuth (real domain callback)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.yourdomain.com/api/v1/auth/google/callback

# MinIO / S3 (internal endpoint; public URL must be reachable by browsers)
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_URL=https://files.yourdomain.com
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me-strong
S3_BUCKET=servio

# SMTP (transactional email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Servio <no-reply@yourdomain.com>"

# --- Web (build-time; set as build args in CI for the web image) ---
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1
# NEXT_PUBLIC_SOCKET_URL=https://api.yourdomain.com
