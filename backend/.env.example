# ───────────────────────────── Backend environment ─────────────────────────────
# Copy to .env and fill real values. Every var here is validated at boot
# (schema validation lands in Milestone 1 — the app refuses to start on bad env).

# App
NODE_ENV=development
API_PORT=5000
# Allowed browser origin for CORS (the Next.js app).
WEB_ORIGIN=http://localhost:3000

# Google OAuth (Milestone 2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# Auth / JWT (Milestone 2)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
REFRESH_TOKEN_TTL_DAYS=30

# Postgres (standard image; cube + earthdistance enabled via init — Milestone 1)
# docker-compose maps host 5434 -> container 5432 (avoids collisions with other stacks).
DATABASE_URL=postgres://postgres:postgres@localhost:5434/marketplace

# Redis (host 6381 -> container 6379)
REDIS_URL=redis://localhost:6381

# MinIO / S3 (host 9004 -> container 9000 API; console on 9005)
MINIO_ENDPOINT=localhost
MINIO_PORT=9004
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=marketplace
MINIO_USE_SSL=false

# SMTP (transactional email via the BullMQ email queue). Leave blank to skip sending.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Servio <no-reply@servio.local>

# Stripe (Milestone 11 — deferred, leave blank)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# WebRTC calling — ICE servers (see docs/calling-feature.md).
# STUN is enough on most networks. For TURN (self-hosted coturn), start it with:
#   docker compose --profile calls up -d coturn
# and set TURN_URLS + TURN_SECRET (secret must match docker/coturn/turnserver.conf).
STUN_URLS=stun:stun.l.google.com:19302
# TURN_URLS=turn:localhost:3478
# TURN_SECRET=dev-turn-secret-change-me
TURN_TTL=86400
